# Frontend Environment Configuration
# Copy this file to .env and update the values as needed

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Laravel API base URL (use same-origin path when deployed behind the backend)
VITE_API_BASE_URL=/api
VITE_BACKEND_URL=http://127.0.0.1:8000

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application name
VITE_APP_NAME="Latest Fashion Jewellery"

# Application version
VITE_APP_VERSION=1.0.0

# Environment (development, staging, production)
VITE_NODE_ENV=development

# Base URL for the frontend application
VITE_BASE_URL=http://localhost:8080

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Google Analytics
VITE_ENABLE_ANALYTICS=false

# Enable error reporting (Sentry)
VITE_ENABLE_ERROR_REPORTING=false

# Enable debug logging in development
VITE_ENABLE_DEBUG_LOGGING=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Google Analytics ID (only if VITE_ENABLE_ANALYTICS=true)
# VITE_GA_ID=GA_MEASUREMENT_ID

# Sentry DSN for error reporting (only if VITE_ENABLE_ERROR_REPORTING=true)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Stripe publishable key for payments
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal client ID
# VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# Social media app IDs
# VITE_FACEBOOK_APP_ID=your-facebook-app-id
# VITE_GOOGLE_CLIENT_ID=your-google-client-id

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable React Query DevTools in development
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true

# Enable Redux DevTools in development
VITE_ENABLE_REDUX_DEVTOOLS=true
